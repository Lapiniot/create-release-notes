{
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */
    "target": "es2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDirs": [
      "src",
      "ts-yaml/src"
    ],
    "outDir": "./lib",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "**/node_modules",
    "./ts-yaml/**/test"
  ]
}